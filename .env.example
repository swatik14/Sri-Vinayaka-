# ============================================================
# Sri Vinayaka Ganapathi Temple — Environment Variables
# Copy this file to .env in the backend/ directory
# ============================================================

# Server
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=vinayaka_temple

# JWT Secret (change this to a strong random string in production)
JWT_SECRET=change_this_to_a_strong_random_secret_key_in_production

# ============================================================
# Frontend env — create frontend/.env.local
# ============================================================
NEXT_PUBLIC_API_URL=http://localhost:5000
